{
  "name": "win-miyabi",
  "version": "0.1.0",
  "description": "Miyabi for Windows - Windows PCでMiyabiを簡単に使えるようにするブリッジパッケージ",
  "type": "module",
  "bin": {
    "win-miyabi": "dist/index.js",
    "wmiyabi": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "templates",
    "docs",
    "README.md",
    "README.ja.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "miyabi",
    "windows",
    "ai",
    "agents",
    "autonomous",
    "automation",
    "cli",
    "claude",
    "anthropic",
    "powershell",
    "wsl2"
  ],
  "author": "Win-Miyabi Contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/colantotte/win-miyabi#readme",
  "bugs": {
    "url": "https://github.com/colantotte/win-miyabi/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cross-spawn": "^7.0.6",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "which": "^4.0.0"
  },
  "peerDependencies": {
    "miyabi": ">=0.19.0"
  },
  "peerDependenciesMeta": {
    "miyabi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.15.0",
    "@types/prompts": "^2.4.9",
    "@types/which": "^3.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
